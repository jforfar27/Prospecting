# RealTrack credentials
REALTRACK_USERNAME=your_username
REALTRACK_PASSWORD=your_password

# Airtable (optional — only needed for --sync)
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_base_id

# Notifications (optional — for run_pipeline.py --notify)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
NOTIFY_EMAIL=you@example.com

# Scheduling (optional — override default weekly cron schedule)
# PIPELINE_CRON_SCHEDULE=0 2 * * 0
